{
  "name": "beangle-setline",
  "version": "0.0.2",
  "description": "A local HTTP path router and transparent proxy.",
  "authors": ["chaostone"],
  "license": "GPL-3.0-or-later",
  "dependencies": {
    "vibe-core": "~>2.10.1"
  },
  "configurations": [
    {
      "name": "application",
      "targetType": "executable",
      "targetPath": "target",
      "sourcePaths": ["src"],
      "dflags": ["-preview=dip1000"]
    },
    {
      "name": "unittest",
      "targetPath": "target",
      "sourcePaths": ["src", "test"],
      "importPaths": ["src", "test"],
      "excludedSourceFiles": ["src/main.d"],
      "dependencies": {
        "silly": "~>1.1.1"
      }
    }
  ]
}
